@page "/material"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using LucroImpresso.Web.Models
@using LucroImpresso.Web.Interfaces
@inject IMaterialRepository MaterialRepo
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>LucroImpresso | Material</PageTitle>

<div class="page-container" style="max-width: 1200px; margin: 0 auto; padding-top: 2rem;">
    <header class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="text-white fw-bold mb-0">GESTÃO DE <span class="neon-text">MATERIAL</span></h2>
            <p class="text-secondary fs-6 mt-1">Gerenciamento master-detail de filamentos.</p>
        </div>
    </header>

    @if (erroCarregamento)
    {
        <div class="alert alert-danger bg-dark text-danger border-danger mb-4">
            Falha na conexão com o banco de dados. Verifique o serviço SQL.
        </div>
    }

    <!-- Topo: Master-Detail Form -->
    <div class="card cyber-card-no-hover p-4 mb-4" style="background-color: var(--secondary-bg); border-color: #2a2a35;">
        <h5 class="text-white mb-3">@(modoEdicao ? "Editar Material" : "Cadastrar Novo Material")</h5>
        
        <EditForm Model="@formularioMaterial" OnValidSubmit="SalvarMaterial" FormName="formMaterial">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger small mb-3" />
            
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label text-secondary small">Nome do Material</label>
                    <InputText @bind-Value="formularioMaterial.Nome" class="form-control cyber-input custom-placeholder" placeholder="Ex: PLA Premium Preto" maxlength="100" />
                    <ValidationMessage For="@(() => formularioMaterial.Nome)" />
                </div>
                <div class="col-md-3">
                    <label class="form-label text-secondary small">Peso Original</label>
                    <div class="input-group">
                        <input type="text" 
                               class="form-control cyber-input custom-placeholder" 
                               placeholder="Ex: 1000" 
                               oninput="window.masks.weightUnit(this)"
                               @onchange="UpdatePeso"
                               value="@pesoFormatted"
                               maxlength="10" />
                        <span class="input-group-text bg-dark text-secondary border-secondary">g</span>
                    </div>
                    <ValidationMessage For="@(() => formularioMaterial.PesoRoloGramas)" />
                </div>
                <div class="col-md-2">
                    <label class="form-label text-secondary small">Saldo Atual</label>
                    <div class="input-group">
                        <input type="text" 
                               class="form-control cyber-input custom-placeholder" 
                               placeholder="Ex: 850" 
                               oninput="window.masks.weightUnit(this)"
                               @onchange="UpdateSaldo"
                               value="@saldoFormatted"
                               maxlength="10" />
                        <span class="input-group-text bg-dark text-secondary border-secondary">g</span>
                    </div>
                    <ValidationMessage For="@(() => formularioMaterial.SaldoGramas)" />
                </div>
                <div class="col-md-2">
                    <label class="form-label text-secondary small">Valor Pago</label>
                    <div class="input-group">
                        <span class="input-group-text bg-dark text-secondary border-secondary">R$</span>
                        <input type="text" 
                               class="form-control cyber-input custom-placeholder" 
                               placeholder="0,00" 
                               oninput="window.masks.money(this)"
                               @onchange="UpdateValorPago"
                               value="@valorPagoFormatted"
                               maxlength="10" />
                    </div>
                    <ValidationMessage For="@(() => formularioMaterial.ValorPago)" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-neon w-100 py-2" disabled="@carregando">
                        @if (carregando)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>AGUARDE...</span>
                        }
                        else
                        {
                            @((modoEdicao ? "ATUALIZAR" : "+ CADASTRAR"))
                        }
                    </button>
                </div>
            </div>
            @if (modoEdicao)
            {
                <div class="d-flex justify-content-end mt-3">
                    <button type="button" class="btn btn-outline-danger py-2 px-4 fw-bold" @onclick="CancelarEdicao" style="border-width: 2px;">
                        ✕ VOLTAR
                    </button>
                </div>
            }
        </EditForm>
    </div>

    <!-- Base: Tabela -->
    <div class="card cyber-card-no-hover p-4 table-responsive" style="background-color: var(--secondary-bg); border-color: #2a2a35;">
        @if (carregando && !materiais.Any())
        {
            <div class="text-center py-5">
                <div class="spinner-border text-info" role="status"></div>
                <p class="text-secondary mt-2">Sincronizando banco de dados...</p>
            </div>
        }
        else
        {
            <table class="table table-dark table-striped table-hover cyber-table mb-0">
            <thead>
                <tr>
                    <th>DATA</th>
                    <th>NOME</th>
                    <th>PESO ORIGINAL</th>
                    <th>SALDO ATUAL</th>
                    <th>VALOR PAGO</th>
                    <th>PREÇO/G</th>
                    <th class="text-center">AÇÕES</th>
                </tr>
            </thead>
            <tbody>
                @if (materiais == null)
                {
                    <tr><td colspan="7" class="text-center text-secondary">Carregando o sistema...</td></tr>
                }
                else if (!materiais.Any())
                {
                    <tr><td colspan="7" class="text-center text-secondary">Nenhum material cadastrado no momento.</td></tr>
                }
                else
                {
                    @foreach (var mat in materiais)
                    {
                        <tr>
                            <td class="align-middle">@mat.DataCadastro.ToString("dd/MM/yyyy")</td>
                            <td class="text-white fw-bold align-middle">@mat.Nome</td>
                            <td class="align-middle">@mat.PesoRoloGramas.ToString("N2") g</td>
                            <td class="align-middle">
                                @if (mat.SaldoGramas <= (mat.PesoRoloGramas * 0.2m))
                                {
                                    <span class="text-danger fw-bold">⚠ @mat.SaldoGramas.ToString("N2") g</span>
                                }
                                else if (mat.SaldoGramas <= (mat.PesoRoloGramas * 0.5m))
                                {
                                    <span class="text-warning fw-bold">⚠ @mat.SaldoGramas.ToString("N2") g</span>
                                }
                                else
                                {
                                    <span style="color: #20c997;">@mat.SaldoGramas.ToString("N2") g</span>
                                }
                            </td>
                            <td class="align-middle">@mat.ValorPago.ToString("C2")</td>
                            <td class="align-middle"><strong class="neon-text">@mat.PrecoPorGrama.ToString("C2")</strong></td>
                            <td class="text-center align-middle">
                                <div class="d-flex justify-content-center gap-2">
                                    <button class="btn btn-outline-warning btn-sm fw-bold" @onclick="() => EditarMaterial(mat)">
                                        <span class="me-1">✏️</span>Editar
                                    </button>
                                    <button class="btn btn-outline-danger btn-sm fw-bold" @onclick="() => ExcluirMaterial(mat.Id)">
                                        <span class="me-1">🗑️</span>Excluir
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
            </table>
        }
    </div>
</div>

<style>
    .custom-placeholder::placeholder { 
        color: #aaaaaa !important; 
        opacity: 1 !important; 
    }
    
    .cyber-card-no-hover:hover {
        border-color: #2a2a35 !important;
        box-shadow: none !important;
        transform: none !important;
    }

    ::deep .table-dark {
        background-color: transparent !important;
    }
    ::deep .table-dark th {
        background-color: #121218 !important;
        color: #8c8c9e !important;
        border-bottom: 2px solid #2a2a35;
    }
    ::deep .table-striped > tbody > tr:nth-of-type(odd) > * {
        background-color: rgba(255, 255, 255, 0.03);
    }
    ::deep .table-hover > tbody > tr:hover > * {
        background-color: rgba(0, 229, 255, 0.1);
        color: var(--text-white);
    }
    ::deep .table-dark td {
        border-color: #2a2a35;
    }
</style>

@code {
    private List<Material> materiais = new();
    private Material formularioMaterial = new();
    private bool erroCarregamento = false;
    private bool modoEdicao = false;
    private bool carregando = false;

    private string pesoFormatted = "";
    private string saldoFormatted = "";
    private string valorPagoFormatted = "";

    private void UpdatePeso(ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? "";
        pesoFormatted = val;
        var clean = val.Replace(".", "").Replace(",", ".");
        if (decimal.TryParse(clean, System.Globalization.CultureInfo.InvariantCulture, out decimal res))
            formularioMaterial.PesoRoloGramas = Math.Max(0, res);
    }

    private void UpdateSaldo(ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? "";
        saldoFormatted = val;
        var clean = val.Replace(".", "").Replace(",", ".");
        if (decimal.TryParse(clean, System.Globalization.CultureInfo.InvariantCulture, out decimal res))
            formularioMaterial.SaldoGramas = Math.Max(0, res);
    }

    private void UpdateValorPago(ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? "";
        valorPagoFormatted = val;
        var clean = val.Replace(".", "").Replace(",", ".").Trim();
        if (decimal.TryParse(clean, System.Globalization.CultureInfo.InvariantCulture, out decimal res))
            formularioMaterial.ValorPago = Math.Max(0, res);
    }

    protected override async Task OnInitializedAsync()
    {
        carregando = true;
        try 
        {
            await CarregarMateriais();
        }
        catch (Exception)
        {
            erroCarregamento = true;
        }
        finally
        {
            carregando = false;
        }
    }

    private async Task SalvarMaterial()
    {
        try 
        {
            carregando = true;
            if (modoEdicao && formularioMaterial.Id > 0)
            {
                await MaterialRepo.UpdateAsync(formularioMaterial);
            }
            else
            {
                if (formularioMaterial.SaldoGramas == 0)
                {
                    formularioMaterial.SaldoGramas = formularioMaterial.PesoRoloGramas;
                }
                formularioMaterial.DataCadastro = DateTime.Now;
                await MaterialRepo.AddAsync(formularioMaterial);
            }
            
            formularioMaterial = new Material(); 
            modoEdicao = false;
            pesoFormatted = "";
            saldoFormatted = "";
            valorPagoFormatted = "";
            await CarregarMateriais();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao salvar material: {ex.Message}");
            erroCarregamento = true;
        }
        finally 
        {
            carregando = false;
            StateHasChanged();
        }
    }

    private void EditarMaterial(Material mat)
    {
        formularioMaterial = new Material
        {
            Id = mat.Id,
            Nome = mat.Nome,
            Cor = mat.Cor,
            PesoRoloGramas = mat.PesoRoloGramas,
            ValorPago = mat.ValorPago,
            SaldoGramas = mat.SaldoGramas,
            DataCadastro = mat.DataCadastro
        };
        pesoFormatted = mat.PesoRoloGramas.ToString("N0");
        saldoFormatted = mat.SaldoGramas.ToString("N0");
        valorPagoFormatted = mat.ValorPago.ToString("C2");
        modoEdicao = true;
    }

    private void CancelarEdicao()
    {
        formularioMaterial = new Material();
        pesoFormatted = "";
        saldoFormatted = "";
        valorPagoFormatted = "";
        modoEdicao = false;
    }

    private async Task ExcluirMaterial(int id)
    {
        bool confirmado = await JS.InvokeAsync<bool>("confirm", "Você deseja realmente deletar esse registro?");
        if (confirmado)
        {
            await MaterialRepo.DeleteAsync(id);
            await CarregarMateriais();
            StateHasChanged();
        }
    }

    private async Task CarregarMateriais()
    {
        materiais = await MaterialRepo.GetAllAsync();
        materiais = materiais.OrderByDescending(m => m.DataCadastro).ToList();
    }
}
